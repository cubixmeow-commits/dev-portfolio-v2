# SousMeow environment configuration (copy to .env — never commit .env)

APP_URL=https://sousmeow.com

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_USERNAME=ChefMeow@sousmeow.com
SMTP_PASSWORD=
MAIL_FROM_ADDRESS=ChefMeow@sousmeow.com
MAIL_FROM_NAME=Chef Meow
MAIL_REPLY_TO=ChefMeow@sousmeow.com

# smtp | log (writes to storage/mail/ without sending)
MAIL_DRIVER=log
